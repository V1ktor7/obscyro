# Simulation service configuration. All optional — sensible defaults apply.

# Where trained model artifacts are read/written: MODEL_DIR/<id>/<version>/.
MODEL_DIR=./artifacts

# Torch device for UDE inference/training.
TORCH_DEVICE=cpu

# Monte-Carlo ensemble sizing (uncertainty bands).
SIM_DEFAULT_RUNS=200
SIM_MAX_RUNS=2000

# Forecast horizon bounds (days).
SIM_DEFAULT_HORIZON_DAYS=60
SIM_MAX_HORIZON_DAYS=365

# Link types treated as location/containment (comma-separated, case-insensitive).
LOCATION_LINK_NAMES=located_in,located_in_bed,assigned_to

# Object types treated as organizational units for predicted-property roll-ups.
UNIT_TYPE_NAMES=orgunit,unit,ward,department,facility
