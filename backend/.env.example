DATABASE_URL=postgresql://obscyro:obscyro_dev_password@localhost:5435/obscyro
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
NLP_SERVICE_URL=http://localhost:5000
# Hybrid ML simulation-service. When unset, ML /simulate falls back to the
# in-process mechanistic SEIR baseline.
SIM_SERVICE_URL=http://localhost:5100
SIM_SERVICE_TIMEOUT_MS=60000
# Optional JSON model-DAG used when a /simulate request omits graphSpec, e.g.
# {"nodes":[{"id":"seir","type":"mechanistic_seir"},{"id":"ude","type":"neural_ode_ude","inputs":["seir"]}],"output":"ude"}
SIM_DEFAULT_GRAPH=
PUBLIC_API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,https://obscyro.vercel.app,https://obscyro.com

# --- Production-hardened feature tunables (all optional; safe defaults shown) ---
# Live digital twin + live metrics SSE cadence and stream behavior
TWIN_SSE_INTERVAL_MS=5000
METRICS_SSE_INTERVAL_MS=5000
SSE_HEARTBEAT_MS=15000
SSE_RETRY_MS=3000

# List endpoint pagination bounds
LIST_DEFAULT_LIMIT=100
LIST_MAX_LIMIT=500

# Max rows pulled into memory for twin rollups / scenario clones / scans
ROLLUP_INSTANCE_CAP=50000

# Simulation Monte-Carlo run ceiling
SIM_MAX_RUNS=200

# Data-quality L6 statistical/ML anomaly layer
DQ_ANOMALY_ENABLED=true
DQ_IQR_K=3.0
DQ_ZSCORE_THRESHOLD=5.0
DQ_ANOMALY_MIN_SAMPLE=12
